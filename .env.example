# ============================================================
# DataServer - Environment Configuration
# Copy this file to .env and fill in all values before running
# ============================================================

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── Database (PostgreSQL) ───────────────────────────────────
POSTGRES_USER=dataserver
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=dataserver
DATABASE_URL=postgresql://dataserver:change_me_strong_password@localhost:5432/dataserver

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6379

# ─── Session & JWT ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING
JWT_SECRET=REPLACE_WITH_ANOTHER_RANDOM_64_BYTE_HEX_STRING
SESSION_MAX_AGE_MS=86400000

# ─── Google OAuth ────────────────────────────────────────────
# Create at https://console.developers.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── S3-Compatible Object Storage (MinIO / AWS S3) ───────────
# S3_ENDPOINT: internal Docker address used by the backend to talk to MinIO
S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_URL: browser-accessible address for pre-signed download/upload URLs
# Set this to the public IP/hostname of your MinIO port, e.g.:
#   http://192.168.1.152:9000   (LAN)
#   https://minio.yourdomain.com  (public, via Cloudflare Tunnel)
# Leave blank to use S3_ENDPOINT (fine for local dev where browser can reach MinIO directly)
S3_PUBLIC_URL=http://192.168.1.152:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_secret_key
S3_BUCKET=dataserver-files
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# MinIO root credentials (used in docker-compose)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret_key

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=DataServer <noreply@dataserver.app>

# ─── ClamAV (Virus Scanning) ─────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ─── Storage Limits ──────────────────────────────────────────
DEFAULT_QUOTA_BYTES=10737418240
MAX_FILE_SIZE_BYTES=2147483648

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_API_MAX=200
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000

# ─── Admin Bootstrap ─────────────────────────────────────────
# Used by seed script to create the first admin account
ADMIN_EMAIL=admin@dataserver.app
ADMIN_PASSWORD=change_me_admin_password
ADMIN_DISPLAY_NAME=Platform Admin
